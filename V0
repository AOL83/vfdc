      <button class="btn-sm" id="exportGithubActionsBtn">⚙️ GHA only</button>
      <label class="btn-sm" style="background:#3e2c1f; cursor:pointer;">📥 Import Blueprint<input type="file" id="importBlueprintFile" accept=".json" style="display:none;"></label>
