  // ================================
  // 10. QUEUED MUTATIONS (restore, reset, import)
  // ================================
  async function captureSnapshot() {
    return enqueue(async () => {
      const snapId = uid();
      const payload = {
        snapshot_id: snapId,
        eventCount: eventLog.length,
        stateHash: await sha256(canonicalize(rebuildStateFromEvents(eventLog)))
      };
      const ev = await createEvent("snapshot.capture", `snapshot.${snapId}`, payload);
      await commitEvent(ev);
      snapshots.unshift({ id: snapId, ts: ev.timestamp, eventCount: eventLog.length - 1, stateHash: payload.stateHash });
      if (snapshots.length > 5) snapshots.pop();
      await persist();
      addLog("📸 Snapshot captured.");
    });
  }

  async function restoreSnapshot() {
    return enqueue(async () => {
      if (!snapshots.length) { addLog("No snapshot"); return; }
      const snap = snapshots[0];
      eventLog = eventLog.slice(0, snap.eventCount);
      snapshots = snapshots.filter(s => s.eventCount <= snap.eventCount);
      settings = rebuildSettingsFromEvents(eventLog);
      const state = rebuildStateFromEvents(eventLog);
      renderedCompute = state.compute; renderedStorage = state.storage; renderedNetwork = state.network; renderedSecurity = state.security;
      await persist();
      renderAll();
      addLog(`♻️ Restored to event #${snap.eventCount}`);
    });
  }

  async function resetFullState() {
    return enqueue(async () => {
      eventLog = [];
      snapshots = [];
      await seedInitialEvents();
      addLog("Factory reset.");
    });
  }

  async function importBlueprint(file) {
    await enqueue(async () => {
      const reader = new FileReader();
      reader.onload = async (e) => {
        try {
          const imported = JSON.parse(e.target.result);
          validateBlueprint(imported);
          const newEvents = [];
          for (const c of imported.compute || []) {
            const ev = await createEventForLog(newEvents, "compute.add", `compute.${c.name}`, { id: uid(), name: c.name, cpu: c.cpu, memory: c.memory || c.mem }, "import");
            validateEvent(ev);
            newEvents.push(ev);
          }
          for (const s of imported.storage || []) {
            const ev = await createEventForLog(newEvents, "storage.add", `storage.${s.name}`, { id: uid(), name: s.name, capacity: s.capacity || s.size }, "import");
            validateEvent(ev);
            newEvents.push(ev);
          }
          for (const n of imported.network || []) {
            const ev = await createEventForLog(newEvents, "network.add", `network.${Date.now()}`, { id: uid(), rule: n.rule }, "import");
            validateEvent(ev);
            newEvents.push(ev);
          }
          for (const p of imported.security || []) {
            const ev = await createEventForLog(newEvents, "security.add", `security.${Date.now()}`, { id: uid(), policy: p.policy }, "import");
            validateEvent(ev);
            newEvents.push(ev);
          }
          await verifyEventChain(newEvents);
          eventLog = newEvents;
          settings = rebuildSettingsFromEvents(eventLog);
          const state = rebuildStateFromEvents(eventLog);
          renderedCompute = state.compute; renderedStorage = state.storage; renderedNetwork = state.network; renderedSecurity = state.security;
          renderAll();
          await persist();
          addLog("📥 Blueprint imported as verified event chain.");
        } catch (err) { addLog(`❌ Import failed: ${err.message}`); }
      };
      reader.readAsText(file);
    });
  }

