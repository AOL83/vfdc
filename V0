  async function resetNetwork() { for(const n of renderedNetwork) await commitAction("network.remove",`network.${n.id}`,{id:n.id}); await commitAction("network.add","net.allow",{id:uid(), rule:"ALLOW 443/TCP"}); await commitAction("network.add","net.deny",{id:uid(), rule:"DENY SSH"}); }
  function rotateSecrets() { addLog("🔐 Secret rotation simulated."); }
  function viewEventLog() { const pre=document.createElement("pre"); pre.textContent=JSON.stringify(eventLog,null,2); const area=document.getElementById("exportPreviewArea"); area.innerHTML=""; area.appendChild(pre); }
  function replayBlueprint() { const state=rebuildStateFromEvents(eventLog); renderedCompute=state.compute; renderedStorage=state.storage; renderedNetwork=state.network; renderedSecurity=state.security; renderAll(); addLog("Blueprint replayed."); }

  // Event binding
  document.getElementById('exportFullProjectBtn').onclick = exportFullProject;
  document.getElementById('exportPatchPackBtn').onclick = exportPatchPack;
  document.getElementById('viewEventLogBtn').onclick = viewEventLog;
  document.getElementById('replayBlueprintBtn').onclick = replayBlueprint;
  document.getElementById('verifyChainBtn').onclick = verifyChain;
  document.getElementById('exportTerraformBtn').onclick = exportTerraformOnly;
  document.getElementById('exportDockerBtn').onclick = exportDockerOnly;
  document.getElementById('exportGithubActionsBtn').onclick = exportGithubActionsOnly;
  document.getElementById('resetFullState').onclick = resetFullState;
  document.getElementById('restoreSnapshotBtn').onclick = restoreSnapshot;
  document.getElementById('addCompute').onclick = addComputeItem;
  document.getElementById('addStorage').onclick = addStorageItem;
  document.getElementById('addNetwork').onclick = addNetworkRule;
  document.getElementById('addSecurity').onclick = addSecurityPolicy;
  document.getElementById('scaleElastic').onclick = autoScale;
  document.getElementById('resetNetwork').onclick = resetNetwork;
  document.getElementById('rotateSecrets').onclick = rotateSecrets;
  document.getElementById('snapshotStorage').onclick = captureSnapshot;
  document.getElementById('saveSettings').onclick = saveSettings;
  document.getElementById('importBlueprintFile').onchange = e => { if(e.target.files[0]) importBlueprint(e.target.files[0]); e.target.value=''; };

  loadPersisted().then(() => addLog("v2.7.2 validation & test harness ready — all event mutations queued, import chain fixed, verifier exits on error, Terraform fmt-compliant."));
</script>
</body>
</html>
